{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Django: migrate",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["manage.py", "migrate"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Django: runserver",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["manage.py", "runserver"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Tailwind: build",
      "type": "process",
      "command": "npm",
      "args": ["run", "tailwind:build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Tailwind: watch",
      "type": "process",
      "command": "npm",
      "args": ["run", "tailwind:watch"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
